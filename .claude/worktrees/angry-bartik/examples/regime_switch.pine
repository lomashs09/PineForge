//@version=5
strategy("Regime-Adaptive Strategy", overlay=true)

// Detect market regime: trending vs ranging
ema_short = ta.ema(close, 10)
ema_long = ta.ema(close, 40)
ema_trend = ta.ema(close, 100)

// ADX proxy: how spread are the EMAs (measures trendiness)
ema_spread = math.abs(ema_short - ema_long)
avg_spread = ta.sma(ema_spread, 50)
is_trending = ema_spread > nz(avg_spread, 0) * 1.2

// Volatility
vol = ta.stdev(close, 20)
vol_avg = ta.sma(vol, 50)
high_vol = nz(vol, 0) > nz(vol_avg, 1) * 1.3

// RSI for mean reversion regime
rsi = ta.rsi(close, 14)

var regime = 0  // 0 = undefined, 1 = trending, 2 = ranging

if is_trending
    regime := 1
else
    regime := 2

// TRENDING REGIME: use momentum/crossover
if regime == 1
    if ta.crossover(ema_short, ema_long) and close > ema_trend
        strategy.entry("Long", strategy.long)
    if ta.crossunder(ema_short, ema_long)
        strategy.close("Long")

// RANGING REGIME: use mean reversion with tight exits
if regime == 2
    sma_mid = ta.sma(close, 20)
    lower_band = sma_mid - nz(vol, 10) * 1.5
    if close < nz(lower_band, 0) and rsi < 35
        strategy.entry("Long", strategy.long)
    if close > nz(sma_mid, 9999) and rsi > 55
        strategy.close("Long")

// Emergency exit on extreme volatility
if high_vol and rsi > 80
    strategy.close("Long")
