//@version=5
strategy("Momentum ROC", overlay=true)

roc_len = input.int(20, "ROC Length")
sma_len = input.int(50, "SMA Filter Length")

momentum = ta.change(close, roc_len)
trend_filter = ta.sma(close, sma_len)

if momentum > 0 and close > trend_filter
    strategy.entry("Long", strategy.long)

if momentum < 0
    strategy.close("Long")

if momentum < 0 and close < trend_filter
    strategy.entry("Short", strategy.short)

if momentum > 0
    strategy.close("Short")
