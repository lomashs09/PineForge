//@version=5
strategy("Bollinger Band Reversion", overlay=true)

length = input.int(20, "BB Length")
mult = input.float(2.0, "BB Multiplier")

basis = ta.sma(close, length)
dev = ta.stdev(close, length) * mult
upper = basis + dev
lower = basis - dev

if close < lower
    strategy.entry("Long", strategy.long)

if close > upper
    strategy.close("Long")
