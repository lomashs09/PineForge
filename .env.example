# MetaAPI credentials — get these from https://app.metaapi.cloud
METAAPI_TOKEN=your-metaapi-token-here
METAAPI_ACCOUNT_ID=your-mt5-account-id-here

# Database
# Local:
# DATABASE_URL=postgresql+asyncpg://pineforge:password@localhost:5432/pineforge
#
# Neon (org org-shiny-haze-85456941, project snowy-morning-81593672):
# 1. Open https://console.neon.tech → your project → Connection details
# 2. Copy the connection string, then change the scheme to postgresql+asyncpg (keep user, password, host, db, ?sslmode=require if shown)
# Example shape (omit ?sslmode= — asyncpg does not accept it; the app adds TLS for *.neon.tech):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/neondb
#
# Use the "-pooler" host if Neon recommends it (serverless / many short connections).
DATABASE_URL=postgresql+asyncpg://pineforge:password@localhost:5432/pineforge

# JWT
JWT_SECRET_KEY=your-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Create Products & Prices in Stripe Dashboard, then paste the price IDs here
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxx
STRIPE_PRICE_EXPERT_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_EXPERT_ANNUAL=price_xxxxxxxxxxxx

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=PineForge <noreply@getpineforge.com>
FRONTEND_URL=http://localhost:5173

# Auth
AUTH_DISABLED=false  # Set true to bypass JWT auth (dev only, NEVER in production)

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
