//@version=5
strategy("Multi-Factor Momentum + ATR Trail", overlay=true, default_qty_value=0.01)

// === PARAMETERS ===
fast_ema_len = input.int(8, "Fast EMA")
mid_ema_len = input.int(21, "Mid EMA")
slow_ema_len = input.int(55, "Slow EMA")
rsi_len = input.int(14, "RSI Length")
rsi_min = input.int(40, "RSI Min for Entry")
rsi_max = input.int(75, "RSI Max for Entry")
atr_len = input.int(14, "ATR Length")
atr_trail_mult = input.float(2.5, "ATR Trail Multiplier")
mom_lookback = input.int(10, "Momentum Lookback")

// === INDICATORS ===
ema_fast = ta.ema(close, fast_ema_len)
ema_mid = ta.ema(close, mid_ema_len)
ema_slow = ta.ema(close, slow_ema_len)
rsi = ta.rsi(close, rsi_len)
atr = ta.atr(atr_len)

// Momentum: rate of change
mom = ta.change(close, mom_lookback)

// Trend strength: EMA alignment score
var trend_score = 0
trend_score := 0
if close > nz(ema_fast, 0) and nz(ema_fast, 0) > nz(ema_mid, 0) and nz(ema_mid, 0) > nz(ema_slow, 0)
    trend_score := 3
else if close > nz(ema_mid, 0) and nz(ema_mid, 0) > nz(ema_slow, 0)
    trend_score := 2
else if close > nz(ema_slow, 0)
    trend_score := 1

// Volatility check: not too volatile
vol = ta.stdev(close, 20)
vol_avg = ta.sma(vol, 50)
vol_ok = nz(vol, 0) < nz(vol_avg, 1) * 2.0

// === TRAILING STOP ===
var trail_stop = 0.0
var in_trade = false

// === ENTRY ===
// Strong trend alignment + positive momentum + RSI in sweet spot + volatility OK
entry_signal = trend_score >= 2 and nz(mom, 0) > 0 and rsi > rsi_min and rsi < rsi_max and vol_ok

if entry_signal and not in_trade
    strategy.entry("Long", strategy.long)
    trail_stop := close - nz(atr, 10) * atr_trail_mult
    in_trade := true

// === TRAIL MANAGEMENT ===
if in_trade
    new_stop = close - nz(atr, 10) * atr_trail_mult
    if new_stop > trail_stop
        trail_stop := new_stop

// === EXIT ===
// Trail stop hit OR trend collapse OR RSI extreme
trend_broken = close < nz(ema_slow, 0)
rsi_extreme = rsi > 85

if in_trade and (close < trail_stop or trend_broken or rsi_extreme)
    strategy.close("Long")
    in_trade := false
    trail_stop := 0.0
