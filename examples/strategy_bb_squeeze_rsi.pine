//@version=5
strategy("BB Squeeze + RSI Mean Reversion", overlay=true, default_qty_value=0.01)

// === PARAMETERS ===
bb_len = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Multiplier")
squeeze_lookback = input.int(120, "Squeeze Lookback")
squeeze_threshold = input.float(0.5, "Squeeze Threshold")
rsi_len = input.int(6, "RSI Length")
rsi_oversold = input.int(25, "RSI Oversold")
rsi_overbought = input.int(75, "RSI Overbought")
exit_bars = input.int(15, "Max Bars in Trade")

// === INDICATORS ===
basis = ta.sma(close, bb_len)
dev = ta.stdev(close, bb_len)
bb_width = nz(dev, 0) * bb_mult * 2
upper = basis + nz(dev, 0) * bb_mult
lower = basis - nz(dev, 0) * bb_mult

// Squeeze detection: BB width is historically narrow
avg_width = ta.sma(bb_width, squeeze_lookback)
in_squeeze = bb_width < nz(avg_width, 999) * squeeze_threshold

// RSI with short period for responsiveness
rsi = ta.rsi(close, rsi_len)

// Track squeeze state
var was_squeezed = false
var bars_since_squeeze = 0
var bars_in_trade = 0

if in_squeeze
    was_squeezed := true
    bars_since_squeeze := 0
else
    bars_since_squeeze := bars_since_squeeze + 1

// === ENTRY CONDITIONS ===
// Buy when: recently in squeeze + RSI oversold + price near/below lower BB
squeeze_ready = was_squeezed and bars_since_squeeze < 15
rsi_oversold_signal = rsi < rsi_oversold
price_at_lower = close < nz(lower, 0) + nz(dev, 1) * 0.3

long_entry = squeeze_ready and rsi_oversold_signal and price_at_lower

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    bars_in_trade := 0
    was_squeezed := false

// === EXIT CONDITIONS ===
if strategy.position_size > 0
    bars_in_trade := bars_in_trade + 1

// Exit on RSI overbought, price at upper BB, or time stop
rsi_exit = rsi > rsi_overbought
price_exit = close > nz(upper, 99999)
time_exit = bars_in_trade > exit_bars

if strategy.position_size > 0 and (rsi_exit or price_exit or time_exit)
    strategy.close("Long")
    bars_in_trade := 0
