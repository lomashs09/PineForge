//@version=5
strategy("MACD + BB Mean Reversion V2", overlay=true, default_qty_value=0.01)

// === PARAMETERS ===
bb_len = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Multiplier")
macd_fast = input.int(12, "MACD Fast EMA")
macd_slow = input.int(26, "MACD Slow EMA")
rsi_len = input.int(14, "RSI Length")
exit_bars_max = input.int(20, "Max Bars in Trade")

// === INDICATORS ===
basis = ta.sma(close, bb_len)
dev = ta.stdev(close, bb_len)
upper = basis + nz(dev, 0) * bb_mult
lower = basis - nz(dev, 0) * bb_mult

// MACD computed manually
ema_f = ta.ema(close, macd_fast)
ema_s = ta.ema(close, macd_slow)
macd_line = nz(ema_f, 0) - nz(ema_s, 0)

rsi = ta.rsi(close, rsi_len)

// Track MACD previous values
var macd_prev = 0.0

// === STATE ===
var bars_in_trade = 0

// === ENTRY CONDITIONS (Relaxed) ===
// Condition 1: Price below lower BB + RSI oversold
entry_bb_rsi = close < nz(lower, 0) and rsi < 35

// Condition 2: Price below basis + MACD turning up from negative
entry_macd_turn = close < nz(basis, 99999) and macd_line > macd_prev and macd_prev < 0 and rsi < 45

// Condition 3: Price near lower BB + RSI recovering from oversold
near_lower = close < nz(basis, 99999) - nz(dev, 0) * bb_mult * 0.3
rsi_recovering = rsi > rsi[1] and rsi < 40
entry_recovery = near_lower and rsi_recovering

if (entry_bb_rsi or entry_macd_turn or entry_recovery) and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    bars_in_trade := 0

// === EXIT CONDITIONS ===
if strategy.position_size > 0
    bars_in_trade := bars_in_trade + 1

// Take profit: price at/above upper BB, or above basis + RSI elevated
profit_exit = close > nz(upper, 99999)
basis_exit = close > nz(basis, 99999) and rsi > 60
// MACD exit: MACD crosses below zero while in profit
macd_bear = macd_line < macd_prev and macd_line < 0 and close > nz(basis, 0)
// Time stop
time_exit = bars_in_trade > exit_bars_max

if strategy.position_size > 0 and (profit_exit or basis_exit or macd_bear or time_exit)
    strategy.close("Long")
    bars_in_trade := 0

// Update history
macd_prev := macd_line
